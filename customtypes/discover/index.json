{
  "format": "page",
  "id": "discover",
  "label": "Discover",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "heading1"
        }
      },
      "search_params": {
        "type": "Group",
        "config": {
          "label": "Search params",
          "repeat": true,
          "fields": {
            "identifier": {
              "type": "Text",
              "config": {
                "label": "identifier",
                "placeholder": ""
              }
            },
            "label": {
              "type": "StructuredText",
              "config": {
                "label": "Label",
                "placeholder": "Artist",
                "allowTargetBlank": true,
                "multi": "heading3,heading4,heading5,strong,paragraph"
              }
            }
          }
        }
      },
      "discover_description": {
        "type": "StructuredText",
        "config": {
          "label": "Discover Description",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,hyperlink,heading5,heading6"
        }
      },
      "no_user_text": {
        "type": "StructuredText",
        "config": {
          "label": "No User Text",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,hyperlink"
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {}
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
